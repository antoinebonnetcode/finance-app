# Finance — Variables d'environnement
# Copier en .env et remplir. Ne jamais committer .env

# ── Google ─────────────────────────────────────────────────────
SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_PATH=credentials/service_account.json

# ── Google OAuth (recommandé pour Drive — remplace le service account) ──
# Obtenir via : python get_oauth_token.py
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# ── Google Drive — dossiers ────────────────────────────────────
DRIVE_FOLDER_FORTUNEO_CC=    # relevés CC (PDF/CSV)
DRIVE_FOLDER_IBKR=           # sauvegarde XML brut IBKR (obligatoire)

# ── IBKR Flex API ──────────────────────────────────────────────
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=

# ── Fortuneo (scraping navigateur) ────────────────────────────
FORTUNEO_LOGIN=              # numéro client Fortuneo
FORTUNEO_PASSWORD=           # code confidentiel (chiffres)

# ── Taux de change fallback ─────────────────────────────────────
FX_USD=0.92
FX_PHP=0.016
FX_TWD=0.028
